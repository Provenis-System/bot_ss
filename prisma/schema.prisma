generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
}

model ScanCase {
  id                String      @id @default(cuid())
  staffDiscordId    String      @map("staff_discord_id")
  selectedGame      String?     @map("selected_game")
  echoScanId        String?     @unique @map("echo_scan_id")
  echoPin           String?     @map("echo_pin")
  echoScanUrl       String?     @map("echo_scan_url")
  status            ScanStatus
  trackingChannelId String      @map("tracking_channel_id")
  trackingMessageId String?     @unique @map("tracking_message_id")
  resultSummary     String?     @map("result_summary")
  resultRaw         Json?       @map("result_raw")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  completedAt       DateTime?   @map("completed_at")
  expiresAt         DateTime?   @map("expires_at")
  logs              ScanLog[]
  verdicts          Verdict[]

  @@index([status, expiresAt])
  @@index([staffDiscordId, createdAt])
  @@map("scan_cases")
}

model Verdict {
  id              String    @id @default(cuid())
  scanCaseId      String?   @map("scan_case_id")
  scanCase        ScanCase? @relation(fields: [scanCaseId], references: [id], onDelete: SetNull)
  staffDiscordId  String    @map("staff_discord_id")
  targetDiscordId String    @map("target_discord_id")
  bannedCity      String    @map("banned_city")
  verdictType     String    @default("banned") @map("verdict_type")
  notes           String?
  proofLink       String?   @map("proof_link")
  proofFileUrls   String[]  @default([]) @map("proof_file_urls")
  logChannelId    String?   @map("log_channel_id")
  logMessageId    String?   @map("log_message_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([targetDiscordId, createdAt])
  @@index([scanCaseId])
  @@map("verdicts")
}

model ScanLog {
  id         String    @id @default(cuid())
  scanCaseId String    @map("scan_case_id")
  action     String
  message    String
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  scanCase   ScanCase  @relation(fields: [scanCaseId], references: [id], onDelete: Cascade)

  @@index([scanCaseId, createdAt])
  @@map("scan_logs")
}

model BotSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bot_settings")
}